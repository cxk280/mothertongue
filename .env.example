# ---- Inference server (server/) ----
# Engine selection: auto | real | fallback
MT_MODE=auto
# cpu | cuda  (set cuda on the Vultr GPU box)
MT_DEVICE=cpu
MT_REGION_LABEL=São Paulo
MT_REGION_CODE=sao
# Model ids (real path only)
MT_STT_MODEL=facebook/mms-1b-all
MT_MT_MODEL=facebook/nllb-200-distilled-600M
MT_TTS_MODEL_TMPL=facebook/mms-tts-{lang}
MT_SAMPLE_RATE=16000
# Set 0 in CI so the fallback doesn't sleep
MT_FALLBACK_SLEEP=1

# ---- Web (web/) ----
# WebSocket URL the browser connects to. Point at the in-region GPU box in prod,
# e.g. wss://sao.mothertongue.example/ws
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
# Simulated cross-ocean round-trip penalty (ms) for the Compare/Race view's us-east
# lane. There is no real US-East endpoint — this is an explicit stand-in.
NEXT_PUBLIC_SIM_USEAST_MS=280
