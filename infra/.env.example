# Vultr credentials + deploy overrides for infra/provision.sh & deploy.sh.
# Copy this to infra/.env (which is gitignored) and fill in — NEVER commit real secrets.
#   cp infra/.env.example infra/.env   # then paste your key
# Get / rotate the key at: https://my.vultr.com/settings/#settingsapi

# Required to provision or query Vultr:
VULTR_API_KEY=

# Optional provision overrides (defaults live in provision.sh):
# MT_VULTR_REGION=sao                  # serving region (note: confirm GPU availability first)
# MT_VULTR_PLAN=vcg-a16-2c-8g-2vram    # a lean Cloud GPU plan
# MT_VULTR_OS_ID=1743                  # Ubuntu 22.04 x64
# MT_VULTR_LABEL=mothertongue-sao

# Deploy target (from provision.sh output):
# MT_HOST=                             # GPU box IP
# MT_SSH_USER=root
